<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SushiTracker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/mint</item>
        <item name="android:colorPrimaryDark">@color/mint_dark</item>
        <item name="android:colorAccent">@color/mint</item>

        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:navigationBarColor">@color/navy_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="android:windowBackground" tools:ignore="DuplicateDefinition">@color/navy</item>
        <item name="android:windowBackground" tools:ignore="DuplicateDefinition">
            @android:color/transparent
        </item>
        <item name="android:windowIsTranslucent">true</item>

        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
</resources>